rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for invoices and product images
    match /invoices/{file} {
      allow read: if true;
      allow write: if false; // server-only writes
    }
    match /images/{file} {
      allow read: if true;
      allow write: if false; // server-only writes
    }
    // Everything else: deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
