# ════════════════════════════════════════════════════════════════
# WhatsApp Commerce Bot — متغيرات البيئة
# ════════════════════════════════════════════════════════════════
# انسخ هذا الملف باسم .env ثم عبّئ القيم الفعلية:
#   cp .env.example .env
# ⚠️  لا ترفع .env إلى GitHub أبداً (موجود في .gitignore)
# ════════════════════════════════════════════════════════════════

# ─── Meta WhatsApp Cloud API ──────────────────────────────────────
# من: developers.facebook.com → التطبيق → WhatsApp → API Setup
# Permanent Token من Meta Business Manager (System User)
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Phone Number ID (رقم 15 خانة من نفس صفحة API Setup)
# ليس رقم الهاتف نفسه — هو معرّف رقمي يعطيك إياه Meta
WHATSAPP_PHONE_ID=123456789012345

# كلمة سرية تخترعها (سترسلها لـ Meta لتأكيد الـ webhook)
VERIFY_TOKEN=my_secret_verify_token_2026

# ─── الأمان ───────────────────────────────────────────────────────
# JWT secret — مطلوب! ≥48 حرف
# توليد قوي: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_128_HEX_CHARS_FROM_CRYPTO_RANDOMBYTES_64

# كلمة المرور لتشفير النسخ الاحتياطية اليومية (GPG AES256)
# توليد: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_PASSPHRASE=REPLACE_WITH_64_HEX_CHARS

# (اختياري) لرفع النسخ الاحتياطية إلى سيرفر بعيد عبر SSH
# BACKUP_REMOTE_SSH=user@remote-host:/backups/thawani

# ─── إعدادات المتجر ────────────────────────────────────────────────
# رقم صاحب المتجر بالصيغة الدولية بدون + (مثال: 966501234567)
# سيستلم إشعارات الطلبات الجديدة على هذا الرقم
OWNER_PHONE=966500000000

# اسم المتجر (يظهر في رسائل الترحيب والفواتير)
STORE_NAME=مقهى النخيل

# عملة المتجر
CURRENCY=ر.س

# رسوم التوصيل الافتراضية
DELIVERY_FEE=10

# أوقات العمل (24 ساعة): البوت يرد برسالة "خارج أوقات العمل" خارج هذا النطاق
WORKING_HOURS_START=8
WORKING_HOURS_END=24

# ─── قاعدة بيانات المنتجات (Google Sheets) ─────────────────────────
# 1. أنشئ Google Sheet بالأعمدة: id, name, category, price, description, available, image_url
# 2. File → Share → Publish to web → CSV → انسخ الرابط
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv&gid=0

# ─── إعدادات الخادم ────────────────────────────────────────────────
# رابط الدومين العام بعد النشر (مطلوب لإرسال صور الفواتير)
# مثال: https://whatsapp-cafe-bot.onrender.com
PUBLIC_URL=

# المنفذ المحلي (Railway/Render سيتجاوزه تلقائياً)
PORT=3000

# مستوى السجلات: info | debug | error
LOG_LEVEL=info

# مسار حفظ الطلبات (افتراضي: ./data/orders.jsonl)
ORDERS_LOG_PATH=./data/orders.jsonl

# ─── (اختياري) Webhook Signature Verification ─────────────────────
# App Secret من Meta لتوقيع الـ webhooks (يحمي من طلبات مزوّرة)
# اتركه فارغاً للتعطيل (موصى به في الإنتاج فقط)
META_APP_SECRET=
